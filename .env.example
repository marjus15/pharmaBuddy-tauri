# Active profile: test (mock UI) or prod (real Supabase AI API)
PHARMABUDDY_PROFILE=test

# Required only when PHARMABUDDY_PROFILE=prod
SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1/get-ai-recommendation
SUPABASE_ANON_KEY=your-anon-key

# Galinos web fallback (prod only): when the barcode is missing from the catalog,
# resolve the drug name from galinos.gr. Defaults to enabled; set to false/0/no/off to disable.
GALINOS_LOOKUP_ENABLED=true

# After a Galinos hit, fire-and-forget upsert into global_product_catalog so the next
# scan is instant. Defaults to enabled; set to false/0/no/off to disable.
GALINOS_CACHE_ENABLED=true

# Advanced commercial-barcode fallback (520/500/505…): Open Food Facts API when catalog,
# local commercial_registry.json, and Galinos all fail. Auto-writes OFF hits to registry.
BARCODE_FALLBACK_ENABLED=true

# National ΕΟΦ (280…) fallback: e-prescription.gr + Farmako CSV + Galinos EOF cross-ref.
EPRESCRIPTION_LOOKUP_ENABLED=true

# Optional override for local commercial barcode overrides (default: %%LOCALAPPDATA%%\pharmaBuddy\commercial_registry.json)
# COMMERCIAL_REGISTRY_PATH=C:\path\to\commercial_registry.json
